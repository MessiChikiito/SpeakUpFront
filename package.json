{
  "name": "speakup-frontend",
  "main": "index.js",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "cross-env EXPO_NO_INTERACTIVE=1 RCT_METRO_PORT=8090 EXPO_WEB_PORT=19006 expo start --web",
    "web:build": "expo export --platform web --clear --output-dir dist",
    "web:serve": "npm run web:build && serve dist -l 5000",
    "lint": "expo lint",
    "cypress:run": "node scripts/run-cypress.js run",
    "cypress:open": "node scripts/run-cypress.js open",
    "e2e": "start-server-and-test web:serve http://localhost:5000 cypress:run",
    "e2e:open": "start-server-and-test web:serve http://localhost:5000 cypress:open"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.1.0",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.4.7",
    "@react-navigation/elements": "^2.3.8",
    "@react-navigation/native": "^7.1.17",
    "@react-navigation/native-stack": "^7.3.26",
    "expo": "~53.0.22",
    "expo-blur": "~14.1.5",
    "expo-constants": "~17.1.7",
    "expo-font": "~13.3.2",
    "expo-haptics": "~14.1.4",
    "expo-image": "~2.4.0",
    "expo-linking": "~7.1.7",
    "expo-splash-screen": "~0.30.10",
    "expo-status-bar": "~2.2.3",
    "expo-symbols": "~0.4.5",
    "expo-system-ui": "~5.0.11",
    "expo-web-browser": "~14.2.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.6",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-web": "~0.20.0",
    "react-native-webview": "13.13.5"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.0.10",
    "cross-env": "^7.0.3",
    "cypress": "^13.17.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~9.2.0",
    "serve": "^14.2.5",
    "start-server-and-test": "^2.1.2",
    "typescript": "~5.8.3"
  },
  "private": true,
  "ts-node": {
    "compilerOptions": {
      "moduleResolution": "node16"
    }
  }
}
